# ==============================================
# JalSeva Environment Variables
# ==============================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Anything prefixed with NEXT_PUBLIC_ is baked into the client JavaScript
# bundle at build time. Restrict these keys at the provider (Firebase
# authorized domains, Maps HTTP-referrer allowlist) — they cannot be kept
# secret.
# ==============================================


# --- Firebase Web (client) -------------------
# All NEXT_PUBLIC_FIREBASE_* values come from your Firebase Web App config
# (Project Settings → General → Your apps → SDK setup and configuration).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=


# --- Firebase Admin (server) -----------------
# On Cloud Run / GCE / any GCP runtime: leave CLIENT_EMAIL and PRIVATE_KEY
# empty. The Admin SDK auto-detects the runtime service-account identity
# via Application Default Credentials (ADC) — no private key is needed
# inside the container. Only set FIREBASE_ADMIN_PROJECT_ID.
#
# For local development with a downloaded service-account JSON, set
# CLIENT_EMAIL and PRIVATE_KEY (escape newlines as \n).
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=
FIREBASE_ADMIN_STORAGE_BUCKET=


# --- Google Maps -----------------------------
# Client key (NEXT_PUBLIC_): restrict by HTTP-referrer to your domain.
# Server key (GOOGLE_MAPS_API_KEY): optional — Haversine fallback is used
# when absent.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_API_KEY=


# --- Google Gemini (Generative Language API) -
GOOGLE_GEMINI_API_KEY=


# --- Razorpay (SIMULATED by default) ---------
# Real keys not required for the MLP demo; payment verification uses
# HMAC-SHA256 against the test secret below.
RAZORPAY_KEY_ID=rzp_sim_jalseva
RAZORPAY_KEY_SECRET=sim_secret_jalseva
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_sim_jalseva


# --- Upstash Redis (optional, L2 cache) ------
# Leave empty to disable the L2 cache layer — code gracefully no-ops.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=


# --- WhatsApp Business (scaffolded) ----------
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=


# --- ONDC / Beckn (SIMULATED) ----------------
ONDC_SUBSCRIBER_ID=jalseva-sim
ONDC_SUBSCRIBER_URL=https://jalseva-sim.in/api/beckn
ONDC_SIGNING_PRIVATE_KEY=sim_key
ONDC_REGISTRY_URL=https://staging.registry.ondc.org


# --- Abuse / billing cap ----------------------
# Hard project-wide cap on real-SMS Phone Auth attempts per UTC day.
# Test phone numbers configured in Firebase bypass this counter (they
# never send SMS and are not billed). Recommended low values for demos.
PHONE_OTP_DAILY_LIMIT=2


# --- Runtime configuration --------------------
# Cloud Run: keep CLUSTER_WORKERS=1 (horizontal autoscaling via instances).
# Self-hosted VM: 0 = one worker per CPU core.
CLUSTER_WORKERS=1
INSTANCE_ID=app-1
SHUTDOWN_TIMEOUT=10000
# Local dev / docker compose only — Cloud Run injects PORT itself.
APP_PORT=3000
NGINX_PORT=80
